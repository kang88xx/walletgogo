# --- EVM (Etherscan V2 unified key covers all supported EVM chains) ---
# Without this, EVM balance checks still work but transaction history is skipped.
ETHERSCAN_API_KEY=

# Optional custom JSON-RPC endpoints (public fallbacks used if unset).
ETHEREUM_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
BASE_RPC_URL=

# --- Solana ---
SOLANA_RPC_URL=

# --- Tron (optional; raises TronGrid rate limits) ---
TRON_PRO_API_KEY=

# --- Storage ---
# Where the JSON store is written (default: ./.data/wallet-gogo.json)
WALLET_GOGO_DATA_FILE=
