# =====================================================================
# Chains
# =====================================================================
# EVM (Etherscan V2 unified key covers all supported EVM chains).
# Without this, EVM balance still works but tx history + token balances are skipped.
ETHERSCAN_API_KEY=

# Optional custom JSON-RPC endpoints (public fallbacks used if unset).
# The default public Ethereum RPC can be flaky; setting a reliable endpoint is recommended.
ETHEREUM_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
BASE_RPC_URL=

# Xphere mainnet (chain id 20250217, native XP). EVM-compatible; native balance
# + balance_change work. Not indexed by Etherscan, so tx-history rules degrade.
XPHERE_RPC_URL=

# Solana (custom RPC recommended for getTransaction enrichment rate limits).
SOLANA_RPC_URL=

# Tron (optional; raises TronGrid rate limits).
TRON_PRO_API_KEY=

# =====================================================================
# Pricing (CoinGecko, USD valuation)
# =====================================================================
# Optional demo/pro API key for higher rate limits. Public API works without it.
COINGECKO_API_KEY=
# Override the API base (e.g. pro-api.coingecko.com/api/v3).
COINGECKO_API_BASE=

# =====================================================================
# Automated polling scheduler
# =====================================================================
# When set, the server-side scheduler auto-starts at this interval (seconds, min 15).
# Leave unset to control polling manually from the UI.
POLL_INTERVAL_SECONDS=

# =====================================================================
# Notifications (all optional; unset channels are silently skipped)
# =====================================================================
# Telegram bot: create a bot via @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord: a channel webhook URL (validated: must be an https discord.com host).
DISCORD_WEBHOOK_URL=

# Console channel: set to 1 to log new alerts to the server console.
NOTIFY_CONSOLE=

# Per-channel routing: minimum severity each channel receives (info|warn|critical).
# e.g. only page Telegram on critical, send everything to Discord. Default: info.
TELEGRAM_MIN_SEVERITY=
DISCORD_MIN_SEVERITY=
CONSOLE_MIN_SEVERITY=

# =====================================================================
# Approval / drainer defense
# =====================================================================
# Comma-separated spender/operator addresses to flag as malicious (critical).
# Known-safe routers (Uniswap, 1inch, Permit2, 0x) are recognized automatically.
MALICIOUS_SPENDERS=

# =====================================================================
# Real-time webhooks (optional; push events instead of/alongside polling)
# =====================================================================
# Alchemy Address Activity webhook signing key -> POST /api/webhooks/alchemy
ALCHEMY_WEBHOOK_SIGNING_KEY=
# Helius webhook Authorization secret -> POST /api/webhooks/helius
HELIUS_WEBHOOK_SECRET=

# =====================================================================
# Storage
# =====================================================================
# Durable store for serverless (Vercel). When these are set, state lives in
# Upstash Redis instead of the local JSON file — required for production, since
# serverless filesystems are ephemeral and not shared across instances.
# Provision via the Vercel Marketplace (Upstash Redis); it injects these keys.
# Native Upstash names:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV marketplace aliases are also accepted (KV_REST_API_URL / KV_REST_API_TOKEN).

# Local/self-hosted fallback: where the JSON store is written when no Redis is
# configured (default: ./.data/wallet-gogo.json).
WALLET_GOGO_DATA_FILE=
